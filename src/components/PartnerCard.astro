---
import { getLogoPath, truncate, parseCity } from '../lib/helpers';

interface Props {
  partner: {
    id: number;
    name: string;
    organization_type: string;
    description: string;
    location: string;
    logo_src: string;
    latitude: number | null;
    longitude: number | null;
  };
}

const { partner } = Astro.props;
const logoPath = getLogoPath(partner.logo_src);
const city = parseCity(partner.location);
---

<article
  class="partner-card card"
  data-type={partner.organization_type}
  data-name={partner.name.toLowerCase()}
  data-desc={partner.description?.toLowerCase()?.slice(0, 300)}
  data-lat={partner.latitude}
  data-lng={partner.longitude}
>
  <a href={`/partners/${partner.id}`} class="partner-card-link">
    <img src={logoPath} alt={partner.name} class="partner-card-logo" loading="lazy" />
    <h3>{partner.name}</h3>
    <span class="tag tag-pink">{partner.organization_type}</span>
    <p class="partner-card-desc">{truncate(partner.description, 100)}</p>
    {city && <p class="partner-card-location">{city}</p>}
  </a>
</article>

<style>
  .partner-card {
    text-align: center;
    padding: 0;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .partner-card:hover {
    transform: translateY(-2px);
    box-shadow: 6px 6px 20px 0 rgba(50, 50, 93, 0.25);
  }

  .partner-card-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 30px 24px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  .partner-card-link:hover {
    color: inherit;
    text-decoration: none;
  }

  .partner-card-logo {
    width: 80px;
    height: 80px;
    object-fit: contain;
    border-radius: 50%;
    background: #f8f8fc;
    margin-bottom: 16px;
  }

  .partner-card h3 {
    font-size: 18px;
    margin-bottom: 8px;
    color: var(--text-dark);
  }
  .partner-card:hover h3 {
    color: var(--purple);
  }

  .partner-card .tag {
    margin-bottom: 10px;
  }

  .partner-card-desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text);
    flex-grow: 1;
    margin-bottom: 8px;
  }

  .partner-card-location {
    font-size: 13px;
    color: var(--text);
    font-weight: 500;
  }

  .partner-card[data-hidden] {
    display: none;
  }
</style>
